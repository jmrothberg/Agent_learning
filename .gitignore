# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Virtualenv
.venv/
venv/
env/
# Dedicated video-generation venv (mlx-gen pins its own mlx; setup.sh step 7)
.venv-video/

# Generated game artifacts (huge + per-session, no point versioning).
# Sessions now write games/<goal-slug>_<ts>.html (+ .best.html sibling),
# so a single glob covers them all.
games/*.html
games/snapshots/
games/traces/
memory/*
!memory/playbook.jsonl
!memory/visual_playtests.jsonl
!memory/prompt_library.jsonl
# Precomputed architect opening library — hand-curated mechanism outlines
# retrieved by retrieve_implementation_outline (k=1, no prompt-bloat risk).
# Distinct from games/game-memory/ which is per-machine learned memory.
!memory/implementation_outlines.jsonl
# Precomputed playtest + audit seeds — also committed as opening-library data.
!memory/playtests.jsonl
!memory/asset_audits.jsonl
!memory/animation_audits.jsonl
# Hand-curated component skill library (paste-ready JS snippets). Same class
# of curated opening-library data as visual_playtests.jsonl — must be tracked.
!memory/components.jsonl
!memory/plan_nudges.jsonl
!memory/feedback_patterns.jsonl
# Default system-test battery — committed project input, useful on all machines
# (moved out of gitignored games/ on 2026-06-02). Read by system_tests.DEFAULT_BATTERY.
!memory/system_battery.jsonl
!memory/skeletons/
!memory/skeletons/*
games/test_*.html
games/tune/
# Serial tune batches (nested HTML/traces — depth-1 globs miss these)
games/tune_serial10/
games/goals/
games/**/overnight.log
games/**/agent_monitor.json
games/system-tests/run_*/
games/eval-traces/
# Asset-pipeline artifacts (PNGs are 50-200KB each; cache grows over time)
games/_asset_cache/
games/_smoke/
games/_draw/
games/_ask_scratch/
games/*_assets/
# Sound-pipeline artifacts (OGGs are 5-50KB each; cache grows over time)
games/_sound_cache/
games/*_sounds/
# Video-pipeline artifacts (MP4s are ~1MB each; Wan2.2 cutscene clips)
games/_video_cache/
games/*_videos/
# Playwright verification screenshots (e.g. dragons-lair-deluxe_shots/)
games/*_shots/
# Per-machine learned memory (won skeletons, live playbook overlay, mistakes).
# Canonical playbook for git is memory/playbook.jsonl only.
games/game-memory/

# Editor / OS noise
.vscode/
.idea/
.DS_Store
*.swp

# Claude harness internals (per-session settings, scheduled-task locks, etc.)
.claude/

# Local API keys for cloud backends (OpenAI, Anthropic). NEVER commit.
# python-dotenv loads .env at chat.py / coder.py startup if present.
.env
.env.*
!.env.example

# Local vLLM vs Ollama bench (machine-specific; never publish)
scripts/bench_vllm_vs_ollama.py
games/bench/

# Local overnight launcher noise
nohup.out
