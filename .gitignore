# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Virtualenv
.venv/
venv/
env/

# Generated game artifacts (huge + per-session, no point versioning).
# Sessions now write games/<goal-slug>_<ts>.html (+ .best.html sibling),
# so a single glob covers them all.
games/*.html
games/snapshots/
games/traces/
games/memory/*
!games/memory/playbook.jsonl
games/test_*.html
games/tune/
# Asset-pipeline artifacts (PNGs are 50-200KB each; cache grows over time)
games/_asset_cache/
games/_smoke/
games/*_assets/
# Sound-pipeline artifacts (OGGs are 5-50KB each; cache grows over time)
games/_sound_cache/
games/*_sounds/

# Editor / OS noise
.vscode/
.idea/
.DS_Store
*.swp

# Claude harness internals (per-session settings, scheduled-task locks, etc.)
.claude/

# Local API keys for cloud backends (OpenAI, Anthropic). NEVER commit.
# python-dotenv loads .env at chat.py / coder.py startup if present.
.env
.env.*
!.env.example
