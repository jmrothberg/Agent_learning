{"id": "state-exposed-on-window", "kind": "playtest", "content": "Expose the game's mutable state on window (window.state or window.game) so acceptance probes can read real fields. State kept only in closure scope is unprobeable and self-probes will read undefined and trivially fail.", "tags": ["state", "window", "probe", "expose", "verify", "canvas"], "source_tier": "root", "verified": true, "helpful": 0, "harmful": 0, "recipe": {"type": "state_expr", "expr": "!!(window.state||window.game||window.gameState)", "err": "game state is not exposed on window.state/window.game — probes cannot read real fields"}, "trace_ids": [], "pass_count": 0, "false_positive_count": 0, "last_verified_at": ""}
